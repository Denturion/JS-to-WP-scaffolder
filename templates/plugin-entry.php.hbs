<?php
/**
 * Plugin Name:       {{plugin.name}}
 * Plugin URI:        {{plugin.pluginUri}}
 * Description:       {{plugin.description}}
 * Version:           {{plugin.version}}
 * Author:            {{plugin.author}}
 * Author URI:        {{plugin.authorUri}}
 * Text Domain:       {{plugin.textDomain}}
 * Domain Path:       /languages
 * Requires at least: {{plugin.minWpVersion}}
 * Requires PHP:      {{plugin.minPhpVersion}}
 *
 * @package {{plugin.namespace}}
 */

if ( ! defined( 'ABSPATH' ) ) {
	exit;
}

/**
 * Composer Autoloader
 *
 * Loads all PSR-4 namespaced classes from src/.
 * Analogous to: Node's require() / ESM import — resolves class files
 * the same way Node resolves modules from node_modules/.
 */
if ( file_exists( __DIR__ . '/vendor/autoload.php' ) ) {
	require_once __DIR__ . '/vendor/autoload.php';
} else {
	add_action(
		'admin_notices',
		function () {
			echo '<div class="notice notice-error"><p>';
			echo '<strong>{{plugin.name}}:</strong> Composer dependencies not found. ';
			echo 'Run <code>composer install</code> in the plugin directory.';
			echo '</p></div>';
		}
	);
	return;
}

/**
 * Plugin Constants
 *
 * Analogous to: process.env.* in Node.js.
 * Defined here (in the bootstrap file) so they are available globally
 * across all classes without needing to pass them around.
 */
define( '{{plugin.constantPrefix}}_VERSION',     '{{plugin.version}}' );
define( '{{plugin.constantPrefix}}_PLUGIN_DIR',  plugin_dir_path( __FILE__ ) );
define( '{{plugin.constantPrefix}}_PLUGIN_URL',  plugin_dir_url( __FILE__ ) );
define( '{{plugin.constantPrefix}}_PLUGIN_FILE', __FILE__ );

/**
 * Bootstrap the plugin.
 *
 * Analogous to: app.listen() in Express — this single call starts everything.
 * Plugin::get_instance() returns the singleton and triggers hook registration
 * via its constructor. Nothing else needs to happen here.
 */
{{plugin.namespace}}\Plugin::get_instance();
