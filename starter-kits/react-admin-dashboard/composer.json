{
    "name": "your-name/react-admin-dashboard",
    "description": "A full-screen React dashboard inside WP Admin. Styled with Tailwind CSS. Feels nothing like WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "ReactAdminDashboard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ReactAdminDashboard\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
